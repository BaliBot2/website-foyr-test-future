---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/home/Navbar.astro';
import Footer from '../components/shared/Footer.astro';
import ContactForm from '../components/contact/ContactForm.astro';
import ContactDetails from '../components/contact/ContactInfo.astro';
import ServiceArea from '../components/contact/ContactMap.astro';
---

<Layout
  title="Contact | Design Sense — Free Consultation, Architecture & Interior Design Delhi NCR"
  description="Contact Design Sense for a free architecture and interior design consultation. Phone: 9899473055. Email: designsenseoffice@gmail.com. Serving Delhi & NCR."
>
  <Navbar />
  <main>
    <!-- Page header -->
    <section class="pt-32 pb-12" style="background-color: var(--color-primary);">
      <div class="max-w-7xl mx-auto px-6">
        <div class="flex items-center gap-4 mb-4">
          <div class="h-px w-12" style="background-color: color-mix(in srgb, var(--color-primary-contrast) 40%, transparent);" />
          <span class="text-xs font-bold uppercase tracking-[0.3em] font-display" style="color: color-mix(in srgb, var(--color-primary-contrast) 60%, transparent);">Get in Touch</span>
        </div>
        <h1
          class="font-display font-black uppercase leading-tight"
          style="color: var(--color-primary-contrast); font-size: clamp(2.5rem, 7vw, 5rem);"
        >
          Let's Build<br />Your Vision
        </h1>
        <p class="font-sans text-lg mt-4 max-w-xl" style="color: color-mix(in srgb, var(--color-primary-contrast) 70%, transparent);">
          Book a free consultation and start your design journey with Ar. Anchal Garg.
        </p>
      </div>
    </section>

    <!-- Form + Details -->
    <section class="py-20 bg-background-light dark:bg-background-dark">
      <div class="max-w-7xl mx-auto px-6">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-16">

          <!-- Left: Form -->
          <div class="lg:col-span-7">
            <ContactForm />
          </div>

          <!-- Right: Details + Map -->
          <div class="lg:col-span-5 space-y-10">
            <ContactDetails />
            <ServiceArea />
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>