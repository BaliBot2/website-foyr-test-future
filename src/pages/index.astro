---
import Layout from '../layouts/Layout.astro';
import FutureHeader from '../components/shared/FutureHeader.astro';
import FutureFooter from '../components/shared/FutureFooter.astro';
import { projects } from '../data/projects';
import { testimonials } from '../data/testimonials';

const featuredProjects = projects.slice(0, 6);
const featuredTestimonials = testimonials.slice(0, 4);

const stats = [
  { label: 'Projects delivered', value: '150+' },
  { label: 'Years of experience', value: '8+' },
  { label: 'Primary service area', value: 'Delhi NCR' },
  { label: 'Project footprint', value: 'Pan India' },
];

const services = [
  {
    code: 'ARC',
    name: 'Architecture',
    description: 'Complete design packages from site planning to execution-ready drawing sets.',
    items: ['Vastu-compliant layouts', '2D and 3D drawing packages', 'Facade and floor planning'],
  },
  {
    code: 'INT',
    name: 'Interiors',
    description: 'Residential, commercial, farmhouse, apartment, and duplex interiors shaped around use and budget.',
    items: ['Concept development', 'Custom furniture detailing', 'Material and lighting coordination'],
  },
  {
    code: 'VIS',
    name: '3D Visualization',
    description: 'Photorealistic previews that let clients resolve decisions before execution begins.',
    items: ['Rendered walkthrough views', 'Presentation imagery', 'Decision support before procurement'],
  },
];

const processSteps = [
  'Understand the brief and constraints',
  'Plan space with circulation and utility first',
  'Develop interior and material concepts',
  'Visualize through realistic 3D views',
  'Procure the right materials and vendors',
  'Coordinate site execution and detailing',
  'Build custom furniture where needed',
  'Style the final space for handover',
];
---

<Layout
  title="Design Sense | Architecture & Interior Design Consultancy - Delhi & NCR"
  description="Design Sense by Ar. Anchal Garg - 150+ delivered projects, architecture and interior design consultancy in Delhi & NCR. Saving client's money, time and stress."
  themeColor="#00E5FF"
  bodyClass="future-body"
>
  <main class="future-home">
    <FutureHeader />

    <section class="future-hero">
      <div class="future-hero__bg">
        <img src="/images/projects/begwani-residence-1.jpg" alt="Design Sense luxury residence project" />
      </div>
      <div class="future-shell future-grid">
        <div class="future-copy">
          <span class="future-eyebrow">Delhi NCR / Architecture / Interiors</span>
          <h1 class="future-title">Spaces worth coming home to.</h1>
          <p class="future-lede">
            Design Sense by Ar. Anchal Garg delivers architecture and interior design that saves the client's money,
            time, and stress while keeping execution grounded in reality.
          </p>
          <div class="future-actions">
            <a href="/contact" class="future-button future-button--solid">Request free consultation</a>
            <a href="/projects" class="future-button future-button--ghost">View portfolio</a>
          </div>
        </div>

        <aside class="future-meta-panel">
          <div class="future-meta-panel__label">Studio highlights</div>
          {stats.map((stat) => (
            <div class="future-meta-panel__item">
              <strong>{stat.label}</strong>
              <span>{stat.value}</span>
            </div>
          ))}
        </aside>
      </div>
    </section>

    <section class="future-marquee" aria-label="Practice summary">
      <div class="future-marquee__track">
        <span>Saving client's money, time, and stress</span>
        <span>Architecture</span>
        <span>Interior design</span>
        <span>3D visualization</span>
        <span>Vastu-compliant planning</span>
        <span>Delhi NCR and Pan India</span>
        <span>Saving client's money, time, and stress</span>
        <span>Architecture</span>
        <span>Interior design</span>
        <span>3D visualization</span>
        <span>Vastu-compliant planning</span>
        <span>Delhi NCR and Pan India</span>
      </div>
    </section>

    <section class="future-section">
      <div class="future-shell future-stats-grid">
        {stats.map((stat) => (
          <article class="future-stat-card">
            <div class="future-stat-card__value">{stat.value}</div>
            <div class="future-stat-card__label">{stat.label}</div>
          </article>
        ))}
      </div>
    </section>

    <section class="future-section">
      <div class="future-shell future-split">
        <div>
          <span class="future-eyebrow">About the practice</span>
          <h2 class="future-section-title">Built around clarity before construction.</h2>
        </div>
        <div class="future-copy">
          <p>
            Design Sense is an architecture and interior design consultancy serving Delhi and NCR, with projects delivered
            across residential, farmhouse, apartment, duplex, and commercial typologies. The core offer is practical design
            direction that translates cleanly into execution.
          </p>
          <article class="future-card future-founder-card">
            <img src="/images/about/anchal-garg-portrait.jpg" alt="Ar. Anchal Garg portrait" />
            <div>
              <p class="future-founder-card__name">Ar. Anchal Garg</p>
              <p class="future-founder-card__role future-microcopy">Founder / Architect / Interior Designer</p>
              <p class="future-form-note">
                IP University graduate with 8+ years of hands-on experience shaping high-end homes, developer spaces, and
                client-first interior transformations.
              </p>
              <div class="future-tag-row">
                <span>B.Arch</span>
                <span>BNI Member</span>
                <span>Client-centric delivery</span>
                <span>Budget-aware execution</span>
              </div>
            </div>
          </article>
        </div>
      </div>
    </section>

    <section class="future-section">
      <div class="future-shell">
        <span class="future-eyebrow">Capabilities</span>
        <h2 class="future-section-title future-section-title--wide">Architecture, interiors, and 3D visualization under one roof.</h2>
        <div class="future-card-grid">
          {services.map((service) => (
            <article class="future-card">
              <div class="future-card__code">{service.code}</div>
              <h3 class="future-card-title">{service.name}</h3>
              <p>{service.description}</p>
              <ul>
                {service.items.map((item) => <li>{item}</li>)}
              </ul>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="future-section">
      <div class="future-shell">
        <span class="future-eyebrow">Pipeline</span>
        <h2 class="future-section-title future-section-title--wide">A clear design process from first brief to final styling.</h2>
        <div class="future-process-list">
          {processSteps.map((step, index) => (
            <div class:list={['future-step', index === 0 && 'future-step--active']}>
              <span class="future-step__num">step_{String(index + 1).padStart(2, '0')}</span>
              <span class="future-step__title">{step}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="future-section">
      <div class="future-shell">
        <div class="future-section-head">
          <div>
            <span class="future-eyebrow">Selected work</span>
            <h2 class="future-section-title">Selected projects across residential and commercial spaces.</h2>
          </div>
          <a href="/projects" class="future-button future-button--ghost">Full portfolio</a>
        </div>

        <div class="future-project-grid future-project-grid--mosaic">
          {featuredProjects.map((project, index) => (
            <article class:list={['future-project-card', index === 0 && 'future-project-card--wide', index === 1 && 'future-project-card--tall']}>
              <img src={project.cover} alt={project.alt} />
              <div class="future-project-card__overlay">
                <span class="future-project-card__tag">{project.type}</span>
                <h3>{project.name}</h3>
                <p>{project.location}{project.sqft ? ` / ${project.sqft.toLocaleString()} sq ft` : ''}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="future-section future-section--bordered">
      <div class="future-shell">
        <span class="future-eyebrow">Client feedback</span>
        <h2 class="future-section-title future-section-title--wide">Reviewed, repeated, and recommended.</h2>
        <div class="future-review-grid">
          {featuredTestimonials.map((item) => (
            <article class="future-review-card">
              <div class="future-review-card__stars">*****</div>
              <p>{item.quote}</p>
              <strong>{item.reviewer}</strong>
              <span class="future-microcopy">{item.badge ?? item.source}</span>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="future-cta">
      <div class="future-shell">
        <span class="future-eyebrow">Contact</span>
        <h2>Ready to design a space that feels like home?</h2>
        <p>
          Book a free consultation with Design Sense and let us help you shape a space that reflects your lifestyle,
          priorities, and budget.
        </p>
        <div class="future-actions">
          <a href="/contact" class="future-button future-button--solid">Book free consultation</a>
          <a href="https://wa.me/919899473055" class="future-button future-button--ghost">WhatsApp</a>
        </div>
      </div>
    </section>

    <FutureFooter />
  </main>
</Layout>
