---
import Layout from '../layouts/Layout.astro';
import { projects } from '../data/projects';
import { testimonials } from '../data/testimonials';

const featuredProjects = projects.slice(0, 6);
const featuredTestimonials = testimonials.slice(0, 4);

const stats = [
  { label: 'Projects delivered', value: '150+' },
  { label: 'Years of experience', value: '8+' },
  { label: 'Primary service area', value: 'Delhi NCR' },
  { label: 'Project footprint', value: 'Pan India' },
];

const services = [
  {
    code: 'ARC',
    name: 'Architecture',
    description: 'Complete design packages from site planning to execution-ready drawing sets.',
    items: ['Vastu-compliant layouts', '2D and 3D drawing packages', 'Facade and floor planning'],
  },
  {
    code: 'INT',
    name: 'Interiors',
    description: 'Residential, commercial, farmhouse, apartment, and duplex interiors shaped around use and budget.',
    items: ['Concept development', 'Custom furniture detailing', 'Material and lighting coordination'],
  },
  {
    code: 'VIS',
    name: '3D Visualization',
    description: 'Photorealistic previews that let clients resolve decisions before execution begins.',
    items: ['Rendered walkthrough views', 'Presentation imagery', 'Decision support before procurement'],
  },
];

const processSteps = [
  'Understand the brief and constraints',
  'Plan space with circulation and utility first',
  'Develop interior and material concepts',
  'Visualize through realistic 3D views',
  'Procure the right materials and vendors',
  'Coordinate site execution and detailing',
  'Build custom furniture where needed',
  'Style the final space for handover',
];
---

<Layout
  title="Design Sense | Futuristic Home Sample"
  description="Futuristic template sample for Design Sense by Ar. Anchal Garg. Design Sense content re-composed into a Cloudflare-deployed futuristic landing page."
  themeColor="#00E5FF"
  bodyClass="future-body"
>
  <main class="future-home">
    <header class="future-header">
      <div class="future-shell future-header__inner">
        <a href="#top" class="future-brand">
          <span class="future-brand__mark"></span>
          <span>Design Sense</span>
        </a>
        <nav class="future-nav" aria-label="Primary">
          <a href="#about">about</a>
          <a href="#services">services</a>
          <a href="#process">process</a>
          <a href="#projects">work</a>
          <a href="#reviews">reviews</a>
        </nav>
        <a href="/contact" class="future-button future-button--solid">Book consult</a>
      </div>
    </header>

    <section id="top" class="hero">
      <div class="hero__bg">
        <img src="/images/projects/begwani-residence-1.jpg" alt="Design Sense luxury residence project" />
      </div>
      <div class="future-shell hero__grid">
        <div class="hero__content">
          <span class="future-eyebrow">Delhi NCR / Architecture / Interiors</span>
          <h1>Spaces worth coming home to.</h1>
          <p class="hero__lede">
            Design Sense by Ar. Anchal Garg delivers architecture and interior design that saves the
            client's money, time, and stress while keeping execution grounded in reality.
          </p>
          <div class="hero__cta">
            <a href="/contact" class="future-button future-button--solid">Request free consultation</a>
            <a href="#projects" class="future-button future-button--ghost">View portfolio</a>
          </div>
        </div>
        <aside class="hero__meta">
          <div class="hero__meta-label">system/studio/meta.json</div>
          {stats.map((stat) => (
            <div class="hero__meta-item">
              <strong>{stat.label}</strong>
              <span>{stat.value}</span>
            </div>
          ))}
        </aside>
      </div>
    </section>

    <section class="future-marquee" aria-label="Practice summary">
      <div class="future-marquee__track">
        <span>Saving client's money, time, and stress</span>
        <span>Architecture</span>
        <span>Interior design</span>
        <span>3D visualization</span>
        <span>Vastu-compliant planning</span>
        <span>Delhi NCR and Pan India</span>
        <span>Saving client's money, time, and stress</span>
        <span>Architecture</span>
        <span>Interior design</span>
        <span>3D visualization</span>
        <span>Vastu-compliant planning</span>
        <span>Delhi NCR and Pan India</span>
      </div>
    </section>

    <section class="future-section">
      <div class="future-shell stats-grid">
        {stats.map((stat) => (
          <article class="stat-card">
            <div class="stat-card__value">{stat.value}</div>
            <div class="stat-card__label">{stat.label}</div>
          </article>
        ))}
      </div>
    </section>

    <section id="about" class="future-section">
      <div class="future-shell about-grid">
        <div>
          <span class="future-eyebrow">About the practice</span>
          <h2 class="section-title">Built around clarity before construction.</h2>
        </div>
        <div class="about-copy">
          <p>
            Design Sense is an architecture and interior design consultancy serving Delhi and NCR,
            with projects delivered across residential, farmhouse, apartment, duplex, and commercial
            typologies. The core offer is practical design direction that translates cleanly into
            execution.
          </p>
          <article class="founder-card">
            <img src="/images/about/anchal-garg-portrait.jpg" alt="Ar. Anchal Garg portrait" />
            <div>
              <p class="founder-card__name">Ar. Anchal Garg</p>
              <p class="founder-card__role">Founder / Architect / Interior Designer</p>
              <p class="founder-card__bio">
                IP University graduate with 8+ years of hands-on experience shaping high-end homes,
                developer spaces, and client-first interior transformations.
              </p>
              <div class="tag-row">
                <span>B.Arch</span>
                <span>BNI Member</span>
                <span>Client-centric delivery</span>
                <span>Budget-aware execution</span>
              </div>
            </div>
          </article>
        </div>
      </div>
    </section>

    <section id="services" class="future-section">
      <div class="future-shell">
        <span class="future-eyebrow">Capabilities</span>
        <h2 class="section-title section-title--wide">The same Design Sense content, recast into a futuristic system.</h2>
        <div class="services-grid">
          {services.map((service) => (
            <article class="service-card">
              <div class="service-card__code">{service.code}</div>
              <h3>{service.name}</h3>
              <p>{service.description}</p>
              <ul>
                {service.items.map((item) => <li>{item}</li>)}
              </ul>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section id="process" class="future-section">
      <div class="future-shell">
        <span class="future-eyebrow">Pipeline</span>
        <h2 class="section-title section-title--wide">A structured delivery flow, shown like a command log.</h2>
        <div class="process-list">
          {processSteps.map((step, index) => (
            <div class:list={['process-item', index === 0 && 'process-item--active']}>
              <span class="process-item__step">step_{String(index + 1).padStart(2, '0')}</span>
              <span class="process-item__title">{step}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section id="projects" class="future-section">
      <div class="future-shell">
        <div class="section-head">
          <div>
            <span class="future-eyebrow">Selected work</span>
            <h2 class="section-title">Real Design Sense projects in the futuristic sample.</h2>
          </div>
          <a href="/projects" class="future-button future-button--ghost">Full portfolio</a>
        </div>
        <div class="project-grid">
          {featuredProjects.map((project, index) => (
            <article class:list={['project-card', index === 0 && 'project-card--wide', index === 1 && 'project-card--tall']}>
              <img src={project.cover} alt={project.alt} />
              <div class="project-card__overlay">
                <span class="project-card__tag">{project.type}</span>
                <h3>{project.name}</h3>
                <p>
                  {project.location}
                  {project.sqft ? ` / ${project.sqft.toLocaleString()} sq ft` : ''}
                </p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section id="reviews" class="future-section future-section--reviews">
      <div class="future-shell">
        <span class="future-eyebrow">Client feedback</span>
        <h2 class="section-title section-title--wide">Reviewed, repeated, and recommended.</h2>
        <div class="review-grid">
          {featuredTestimonials.map((item) => (
            <article class="review-card">
              <div class="review-card__stars">{'*****'}</div>
              <p>{item.quote}</p>
              <strong>{item.reviewer}</strong>
              <span>{item.badge ?? item.source}</span>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section id="contact" class="future-cta">
      <div class="future-shell">
        <span class="future-eyebrow">Contact</span>
        <h2>Ready to translate this theme into the full site?</h2>
        <p>
          This sample keeps the existing Design Sense content but changes the visual system to the
          futuristic template direction. Next passes can extend the same treatment to the inner pages
          or to the other template families.
        </p>
        <div class="hero__cta">
          <a href="/contact" class="future-button future-button--solid">Open contact page</a>
          <a href="https://wa.me/919899473055" class="future-button future-button--ghost">WhatsApp</a>
        </div>
      </div>
    </section>

    <footer class="future-footer">
      <div class="future-shell future-footer__grid">
        <div>
          <p class="future-footer__brand">Design Sense</p>
          <p class="future-footer__copy">
            Architecture and interior design consultancy based in Delhi NCR, delivering spaces that
            reduce friction before execution begins.
          </p>
        </div>
        <div>
          <h3>Contact</h3>
          <a href="tel:9899473055">9899473055</a>
          <a href="mailto:designsenseoffice@gmail.com">designsenseoffice@gmail.com</a>
          <span>Delhi NCR</span>
        </div>
        <div>
          <h3>Network</h3>
          <a href="https://www.instagram.com/designsense.architects" target="_blank" rel="noreferrer">Instagram</a>
          <a href="https://www.designsensearchitects.com" target="_blank" rel="noreferrer">Website</a>
          <a href="/projects">Portfolio</a>
        </div>
      </div>
    </footer>
  </main>
</Layout>

<style>
  :global(body.future-body) {
    background:
      linear-gradient(to right, rgba(31, 42, 54, 0.55) 1px, transparent 1px) 0 0 / 80px 100%,
      radial-gradient(circle at top, rgba(0, 229, 255, 0.12), transparent 35%),
      #0b0f14;
    color: #e8f2f7;
  }

  .future-home {
    color: #e8f2f7;
    background: transparent;
  }

  .future-shell {
    width: min(1320px, calc(100% - 40px));
    margin: 0 auto;
  }

  .future-header {
    position: sticky;
    top: 0;
    z-index: 50;
    border-bottom: 1px solid #1f2a36;
    background: rgba(11, 15, 20, 0.9);
    backdrop-filter: blur(12px);
  }

  .future-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    min-height: 72px;
  }

  .future-brand {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 1.1rem;
    font-weight: 700;
    letter-spacing: -0.03em;
  }

  .future-brand__mark {
    width: 10px;
    height: 10px;
    border-radius: 999px;
    background: #00e5ff;
    box-shadow: 0 0 18px rgba(0, 229, 255, 0.7);
  }

  .future-nav {
    display: flex;
    gap: 28px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.76rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #7d8b99;
  }

  .future-nav a:hover,
  .future-footer a:hover {
    color: #00e5ff;
  }

  .future-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 46px;
    padding: 0 20px;
    border: 1px solid #2d3d52;
    border-radius: 4px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    transition: 0.2s ease;
  }

  .future-button:hover {
    transform: translateY(-1px);
  }

  .future-button--solid {
    border-color: #00e5ff;
    background: #00e5ff;
    color: #0b0f14;
    box-shadow: 0 0 22px rgba(0, 229, 255, 0.32);
  }

  .future-button--ghost {
    color: #e8f2f7;
    background: rgba(19, 26, 34, 0.75);
  }

  .future-button--ghost:hover {
    border-color: #00e5ff;
    color: #00e5ff;
  }

  .future-eyebrow {
    display: inline-flex;
    align-items: center;
    min-height: 30px;
    padding: 0 12px;
    border: 1px solid #2d3d52;
    color: #00e5ff;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.7rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .hero {
    position: relative;
    overflow: hidden;
    padding: 96px 0 80px;
  }

  .hero__bg {
    position: absolute;
    inset: 0;
    opacity: 0.22;
  }

  .hero__bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(to right, rgba(31, 42, 54, 0.42) 1px, transparent 1px) 0 0 / 60px 100%,
      linear-gradient(to bottom, rgba(31, 42, 54, 0.42) 1px, transparent 1px) 0 0 / 100% 60px,
      linear-gradient(180deg, rgba(11, 15, 20, 0.4), rgba(11, 15, 20, 0.92));
  }

  .hero__bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(0.25) contrast(1.05);
  }

  .hero__grid {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 1.7fr) minmax(280px, 0.9fr);
    gap: 56px;
    align-items: end;
  }

  .hero__content h1,
  .section-title,
  .future-cta h2 {
    margin: 18px 0 0;
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 700;
    letter-spacing: -0.05em;
    line-height: 0.95;
  }

  .hero__content h1 {
    max-width: 8ch;
    font-size: clamp(3.8rem, 10vw, 8.8rem);
  }

  .hero__lede,
  .about-copy p,
  .future-cta p {
    max-width: 60ch;
    margin: 28px 0 0;
    color: #9badbc;
    font-size: 1.05rem;
    line-height: 1.75;
  }

  .hero__cta {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    margin-top: 32px;
  }

  .hero__meta {
    display: grid;
    overflow: hidden;
    border: 1px solid #2d3d52;
    background: rgba(19, 26, 34, 0.92);
  }

  .hero__meta-label,
  .hero__meta-item {
    padding: 14px 18px;
    font-family: 'JetBrains Mono', monospace;
    border-bottom: 1px solid #1f2a36;
  }

  .hero__meta-label {
    color: #738090;
    font-size: 0.72rem;
    letter-spacing: 0.12em;
  }

  .hero__meta-item:last-child {
    border-bottom: 0;
  }

  .hero__meta-item strong,
  .stat-card__label,
  .founder-card__role,
  .review-card span,
  .future-footer h3 {
    display: block;
    color: #738090;
    font-size: 0.72rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .hero__meta-item span {
    display: block;
    margin-top: 8px;
    color: #e8f2f7;
    font-size: 1rem;
  }

  .future-marquee {
    overflow: hidden;
    border-top: 1px solid #2d3d52;
    border-bottom: 1px solid #2d3d52;
    background: rgba(19, 26, 34, 0.84);
  }

  .future-marquee__track {
    display: flex;
    gap: 28px;
    white-space: nowrap;
    padding: 16px 0;
    animation: marquee 34s linear infinite;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.8rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #00e5ff;
  }

  .future-marquee__track span::after {
    content: '/';
    margin-left: 28px;
    color: #5c6977;
  }

  .future-section {
    padding: 88px 0;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    border: 1px solid #2d3d52;
    background: rgba(19, 26, 34, 0.88);
  }

  .stat-card {
    padding: 44px 28px;
    border-right: 1px solid #1f2a36;
  }

  .stat-card:last-child {
    border-right: 0;
  }

  .stat-card__value {
    font-family: 'Space Grotesk', sans-serif;
    font-size: clamp(2.4rem, 5vw, 4.6rem);
    font-weight: 700;
    letter-spacing: -0.05em;
    line-height: 1;
  }

  .stat-card__label {
    margin-top: 12px;
  }

  .about-grid,
  .section-head,
  .future-footer__grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1.35fr);
    gap: 48px;
  }

  .section-title {
    font-size: clamp(2.6rem, 5vw, 4.4rem);
  }

  .section-title--wide {
    max-width: 14ch;
  }

  .founder-card,
  .service-card,
  .review-card {
    margin-top: 28px;
    background: rgba(19, 26, 34, 0.92);
    border: 1px solid #2d3d52;
  }

  .founder-card {
    display: grid;
    grid-template-columns: 180px minmax(0, 1fr);
    gap: 24px;
    padding: 24px;
  }

  .founder-card img {
    width: 100%;
    aspect-ratio: 1;
    object-fit: cover;
    border: 1px solid #2d3d52;
    filter: grayscale(0.2) contrast(1.08) hue-rotate(180deg);
  }

  .founder-card__name,
  .service-card h3,
  .project-card h3,
  .review-card strong,
  .future-footer__brand {
    margin: 0;
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 700;
    letter-spacing: -0.03em;
  }

  .founder-card__name {
    font-size: 1.6rem;
    color: #00e5ff;
  }

  .founder-card__bio {
    font-size: 0.95rem;
  }

  .tag-row {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 20px;
  }

  .tag-row span,
  .project-card__tag {
    display: inline-flex;
    align-items: center;
    min-height: 28px;
    padding: 0 10px;
    border: 1px solid rgba(0, 229, 255, 0.32);
    background: rgba(0, 229, 255, 0.08);
    color: #00e5ff;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.68rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .services-grid,
  .review-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 20px;
    margin-top: 36px;
  }

  .service-card {
    padding: 32px 28px;
    border-top: 2px solid #00e5ff;
  }

  .service-card__code,
  .process-item__step {
    color: #00e5ff;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.74rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .service-card h3 {
    margin-top: 16px;
    font-size: 1.8rem;
  }

  .service-card p {
    margin: 12px 0 0;
    color: #9badbc;
    line-height: 1.7;
  }

  .service-card ul {
    margin: 20px 0 0;
    padding: 20px 0 0;
    border-top: 1px solid #1f2a36;
    list-style: none;
  }

  .service-card li + li {
    margin-top: 10px;
  }

  .service-card li::before {
    content: '> ';
    color: #00e5ff;
    font-family: 'JetBrains Mono', monospace;
  }

  .process-list {
    margin-top: 36px;
    border: 1px solid #2d3d52;
    background: rgba(19, 26, 34, 0.9);
  }

  .process-item {
    display: grid;
    grid-template-columns: 140px minmax(0, 1fr);
    gap: 24px;
    padding: 18px 20px;
    border-bottom: 1px solid #1f2a36;
  }

  .process-item:last-child {
    border-bottom: 0;
  }

  .process-item--active .process-item__step {
    text-shadow: 0 0 14px rgba(0, 229, 255, 0.8);
  }

  .process-item__title {
    color: #d7e5ef;
    font-size: 1rem;
  }

  .section-head {
    align-items: end;
    grid-template-columns: minmax(0, 1fr) auto;
  }

  .project-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    grid-auto-rows: 290px;
    gap: 16px;
    margin-top: 36px;
  }

  .project-card {
    position: relative;
    overflow: hidden;
    border: 1px solid #2d3d52;
    background: #131a22;
  }

  .project-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(0.22) contrast(1.05);
    transition: transform 0.3s ease, filter 0.3s ease;
  }

  .project-card:hover img {
    transform: scale(1.03);
    filter: grayscale(0) contrast(1.06);
  }

  .project-card__overlay {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 24px;
    background: linear-gradient(180deg, rgba(11, 15, 20, 0.02), rgba(11, 15, 20, 0.9));
  }

  .project-card__overlay h3 {
    margin-top: 12px;
    font-size: 1.35rem;
  }

  .project-card__overlay p {
    margin: 8px 0 0;
    color: #9badbc;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .project-card--wide {
    grid-column: span 2;
  }

  .project-card--tall {
    grid-row: span 2;
  }

  .future-section--reviews {
    border-top: 1px solid #1f2a36;
    border-bottom: 1px solid #1f2a36;
    background: rgba(11, 15, 20, 0.5);
  }

  .review-grid {
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  .review-card {
    padding: 28px 24px;
  }

  .review-card__stars {
    color: #00e5ff;
    font-family: 'JetBrains Mono', monospace;
    letter-spacing: 0.22em;
  }

  .review-card p {
    margin: 18px 0;
    color: #d8e5ee;
    line-height: 1.7;
  }

  .review-card strong {
    font-size: 1rem;
    color: #00e5ff;
  }

  .future-cta {
    padding: 104px 0;
    border-top: 1px solid #00e5ff;
