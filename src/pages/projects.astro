---
import Layout from '../layouts/Layout.astro';
import FutureHeader from '../components/shared/FutureHeader.astro';
import FutureFooter from '../components/shared/FutureFooter.astro';
import { projects, projectTypes } from '../data/projects';

const featuredProjects = projects.filter((project) => project.featured).slice(0, 6);
const groupedProjects = projectTypes.map((type) => ({
  type,
  items: projects.filter((project) => project.type === type),
})).filter((group) => group.items.length > 0);
---

<Layout
  title="Portfolio | Design Sense - 150+ Architecture & Interior Design Projects, Delhi NCR"
  description="Browse Design Sense's portfolio of 150+ projects - residential, commercial, farmhouse, apartments, and duplex designs across Delhi & NCR by Ar. Anchal Garg."
  themeColor="#00E5FF"
  bodyClass="future-body"
>
  <main class="future-page">
    <FutureHeader />

    <section class="future-page-hero future-page-hero--compact">
      <div class="future-page-hero__bg">
        <img src="/images/projects/pioneer-araya-1.jpg" alt="Design Sense project portfolio hero" />
      </div>
      <div class="future-shell future-two-col">
        <div class="future-copy">
          <span class="future-eyebrow">Portfolio / Delivered work</span>
          <h1 class="future-title future-page-title">A portfolio built from real briefs, not speculative visuals.</h1>
          <p class="future-lede">
            The project set spans residences, apartments, duplexes, farmhouses, and commercial interiors, with each space
            shaped around how it will actually be used.
          </p>
        </div>

        <aside class="future-meta-panel">
          <div class="future-meta-panel__label">Portfolio overview</div>
          <div class="future-meta-panel__item">
            <strong>Visible projects</strong>
            <span>{projects.length}</span>
          </div>
          <div class="future-meta-panel__item">
            <strong>Categories</strong>
            <span>{projectTypes.join(' / ')}</span>
          </div>
          <div class="future-meta-panel__item">
            <strong>Delivery range</strong>
            <span>Delhi NCR / Gurgaon / Rewari</span>
          </div>
        </aside>
      </div>
    </section>

    <section class="future-section">
      <div class="future-shell">
        <span class="future-eyebrow">Featured work</span>
        <h2 class="future-section-title future-section-title--wide">Featured projects from our portfolio.</h2>
        <div class="future-project-grid future-project-grid--mosaic">
          {featuredProjects.map((project, index) => (
            <article class:list={['future-project-card', index === 0 && 'future-project-card--wide', index === 1 && 'future-project-card--tall']}>
              <img src={project.cover} alt={project.alt} />
              <div class="future-project-card__overlay">
                <span class="future-project-card__tag">{project.type}</span>
                <h3>{project.name}</h3>
                <p>{project.location}{project.sqft ? ` / ${project.sqft.toLocaleString()} sq ft` : ''}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="future-section future-section--bordered">
      <div class="future-shell">
        <span class="future-eyebrow">Archive</span>
        <h2 class="future-section-title future-section-title--wide">Explore projects by type.</h2>

        {groupedProjects.map((group) => (
          <div class="future-archive">
            <div class="future-section-head">
              <div>
                <h3 class="future-card-title">{group.type}</h3>
                <p class="future-form-note">{group.items.length} project{group.items.length > 1 ? 's' : ''}</p>
              </div>
            </div>

            <div class="future-list-grid">
              {group.items.map((project) => (
                <article class="future-list-card">
                  <img src={project.cover} alt={project.alt} />
                  <div class="future-list-card__meta">
                    {project.location}
                    {project.sqft ? ` / ${project.sqft.toLocaleString()} sq ft` : ''}
                  </div>
                  <h3>{project.name}</h3>
                  <p>{project.description}</p>
                  <div class="future-chip-row">
                    <span class="future-chip">{project.type}</span>
                    {project.images && <span class="future-chip">{project.images.length + 1} visuals</span>}
                  </div>
                </article>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>

    <section class="future-cta">
      <div class="future-shell">
        <span class="future-eyebrow">Inquiry</span>
        <h2>Need a reference closer to your own project type?</h2>
        <p>Reach out with your location, scale, and intent. The studio can share the right precedent and scope direction.</p>
        <div class="future-actions">
          <a href="/contact" class="future-button future-button--solid">Start your project</a>
          <a href="https://wa.me/919899473055" class="future-button future-button--ghost">WhatsApp</a>
        </div>
      </div>
    </section>

    <FutureFooter />
  </main>
</Layout>
