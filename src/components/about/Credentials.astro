---
// Credentials.astro — BNI Proud Member + trust signals
---

<section id="credentials" class="py-20 bg-stone-100 dark:bg-background-dark/60">
  <div class="max-w-7xl mx-auto px-6">
    <div class="flex flex-col lg:flex-row items-center justify-between gap-10 p-10 rounded-xl border" style="border-color: color-mix(in srgb, var(--color-primary) 20%, transparent); background-color: var(--color-background-light);">

      <!-- BNI Badge block -->
      <div class="flex flex-col sm:flex-row items-center gap-6">
        <!-- BNI Badge visual -->
        <div
          class="w-20 h-20 rounded-full flex items-center justify-center shrink-0 border-2"
          style="border-color: var(--color-primary); background-color: color-mix(in srgb, var(--color-primary) 10%, transparent);"
        >
          <div class="text-center">
            <div class="font-display font-black text-xl text-primary leading-none">BNI</div>
            <div class="font-sans text-[8px] uppercase tracking-wider text-primary mt-0.5">Member</div>
          </div>
        </div>
        <div>
          <p class="font-display font-black text-lg uppercase tracking-wide text-stone-900 dark:text-stone-100 mb-1">
            Proud BNI Member
          </p>
          <p class="font-sans text-sm text-stone-600 dark:text-stone-400 max-w-md">
            Design Sense is a proud member of <strong>Business Network International (BNI)</strong> — the world's largest business networking organisation. BNI membership reflects our commitment to professional excellence and peer-reviewed trust.
          </p>
        </div>
      </div>

      <!-- Trust signals -->
      <div class="flex flex-wrap gap-4 lg:flex-col lg:gap-3">
        {[
          { icon: '✓', text: '150+ Happy Clients' },
          { icon: '✓', text: 'On-Time Delivery' },
          { icon: '✓', text: 'Transparent Pricing' },
          { icon: '✓', text: 'End-to-End Service' },
        ].map(({ icon, text }) => (
          <div class="flex items-center gap-2">
            <span class="font-bold text-primary">{icon}</span>
            <span class="font-sans text-sm text-stone-700 dark:text-stone-300 font-medium">{text}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
