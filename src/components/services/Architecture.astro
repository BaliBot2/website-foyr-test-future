---
// Services: Architecture — 7-item service list
---

<section id="architecture-services" class="pt-32 pb-24 bg-background-light dark:bg-background-dark">
  <div class="max-w-7xl mx-auto px-6">

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 items-start">

      <!-- Left: header + description -->
      <div class="lg:col-span-5 space-y-6">
        <div>
          <div class="flex items-center gap-4 mb-4">
            <div class="h-px w-12 bg-primary" />
            <span class="text-xs font-bold uppercase tracking-[0.3em] text-primary font-display">Category A</span>
          </div>
          <h1 class="font-display font-black uppercase text-stone-900 dark:text-stone-100 leading-tight" style="font-size: clamp(2.5rem, 5vw, 4rem);">
            Architecture<br />Services
          </h1>
        </div>
        <p class="font-sans text-stone-600 dark:text-stone-400 leading-relaxed">
          Complete architectural design packages from site analysis to structural execution — all Vastu-compliant and delivered as both 2D & 3D drawings.
        </p>

        <!-- Image: Architectural Plans -->
        <div class="rounded-lg overflow-hidden aspect-square max-w-sm relative bg-stone-200 dark:bg-stone-800 shadow-xl">
          <img
            src="/images/hero/drawings.jpg"
            alt="Design Sense architectural drawing and layout plan"
            class="absolute inset-0 w-full h-full object-cover object-left-top transition-transform duration-700 hover:scale-105"
            loading="lazy"
            decoding="async"
          />
        </div>
      </div>

      <!-- Right: service list -->
      <div class="lg:col-span-7">
        <div
          class="rounded-xl p-8 md:p-10 space-y-4"
          style="background-color: color-mix(in srgb, var(--color-primary) 4%, var(--color-background-light)); border: 1px solid color-mix(in srgb, var(--color-primary) 15%, transparent);"
        >
          <p class="font-display font-black text-sm uppercase tracking-widest text-primary mb-6">
            What's Included
          </p>
          <ol class="space-y-4">
            {[
              'Complete architectural drawings set (Vastu-compliant layouts)',
              'Furniture setting layout design',
              'Electrical drawings for walls and ceilings — all floors',
              'Plumbing and sanitation drawings — all floors',
              'Elevation design — 2D and 3D',
              'Detailed elevation drawings (electrical, railing, gate details)',
              'Complete structural drawings (by expert structural consultants)',
            ].map((item, i) => (
              <li class="flex items-start gap-4 group">
                <span
                  class="flex-shrink-0 w-8 h-8 rounded-full flex items-center justify-center font-display font-black text-sm transition-colors duration-200"
                  style="background-color: var(--color-primary); color: var(--color-primary-contrast);"
                >
                  {String(i + 1).padStart(2, '0')}
                </span>
                <span class="font-sans text-stone-700 dark:text-stone-300 pt-1 leading-relaxed group-hover:text-stone-900 dark:group-hover:text-stone-100 transition-colors">
                  {item}
                </span>
              </li>
            ))}
          </ol>
        </div>

        <div class="mt-8">
          <a
            href="/contact"
            class="inline-flex items-center gap-2 bg-primary hover:bg-primary-light text-primary-contrast px-8 py-4 rounded font-bold uppercase tracking-widest text-sm transition-all duration-200 hover:scale-105"
          >
            Request Architecture Quote
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
