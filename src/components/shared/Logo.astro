---
export interface Props {
  class?: string;
  size?: 'sm' | 'md' | 'lg';
}

const { class: className = '', size = 'md' } = Astro.props;

const sizeClasses = {
  sm: 'h-8 text-xs',
  md: 'h-10 text-sm',
  lg: 'h-12 text-base'
};
---

<!-- DS Monogram Mark -->
<div class:list={['inline-flex items-center justify-center rounded-sm bg-primary text-primary-contrast font-display font-black tracking-tighter aspect-square', sizeClasses[size], className]}>
  DS
</div>