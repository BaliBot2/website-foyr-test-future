---
// Testimonials.astro — Google Review cards from data
import { testimonials } from '../../data/testimonials';
---

<section id="testimonials" class="py-24 bg-background-light dark:bg-background-dark">
  <div class="max-w-7xl mx-auto px-6">

    <!-- Header -->
    <div class="text-center mb-14">
      <div class="flex items-center gap-4 justify-center mb-4">
        <div class="h-px w-12 bg-primary" />
        <span class="text-xs font-bold uppercase tracking-[0.3em] text-primary font-display">Client Voices</span>
        <div class="h-px w-12 bg-primary" />
      </div>
      <h2 class="font-display font-black uppercase text-stone-900 dark:text-stone-100 leading-tight" style="font-size: clamp(2rem, 5vw, 3.5rem);">
        What Our Clients Say
      </h2>
      <p class="font-sans text-stone-500 dark:text-stone-400 mt-3">
        All reviews verbatim from Google. 5★ average.
      </p>
    </div>

    <!-- Cards grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {testimonials.map((t) => (
        <article class="bg-white dark:bg-stone-900 rounded-lg border border-stone-200 dark:border-stone-800 p-6 flex flex-col gap-4 hover:border-primary/30 hover:shadow-md transition-all duration-300 group">

          <!-- Google badge + stars -->
          <div class="flex items-center justify-between">
            <!-- Stars -->
            <div class="flex gap-0.5" aria-label={`${t.rating} out of 5 stars`}>
              {Array.from({ length: t.rating }).map(() => (
                <svg class="w-4 h-4 star-filled" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                </svg>
              ))}
            </div>
            <!-- Google badge -->
            <span class="text-[10px] font-bold uppercase tracking-widest px-2 py-1 rounded bg-stone-100 dark:bg-stone-800 text-stone-500 dark:text-stone-400 font-sans">
              Google Review
            </span>
          </div>

          <!-- Quote -->
          <blockquote class="font-sans text-sm text-stone-700 dark:text-stone-300 leading-relaxed flex-1 italic">
            "{t.quote}"
          </blockquote>

          <!-- Reviewer -->
          <footer class="flex items-center gap-3 pt-3 border-t border-stone-100 dark:border-stone-800">
            <!-- Avatar initial -->
            <div
              class="w-9 h-9 rounded-full flex items-center justify-center font-display font-black text-sm shrink-0"
              style="background-color: var(--color-primary); color: var(--color-primary-contrast);"
            >
              {t.reviewer.charAt(0)}
            </div>
            <div>
              <p class="font-sans font-semibold text-sm text-stone-900 dark:text-stone-100">{t.reviewer}</p>
              {t.badge && (
                <p class="font-sans text-[10px] text-stone-400 uppercase tracking-wide">{t.badge}</p>
              )}
            </div>
          </footer>
        </article>
      ))}
    </div>

    <!-- CTA -->
    <div class="text-center mt-10">
      <a
        href="https://www.google.com/maps/search/Design+Sense+Architects+Delhi"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 text-sm font-semibold text-primary hover:text-primary-light transition-colors font-sans"
      >
        Read More Reviews on Google
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
        </svg>
      </a>
    </div>
  </div>
</section>
