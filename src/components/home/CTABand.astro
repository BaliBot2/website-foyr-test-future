---
// CTABand.astro — Rust CTA section at bottom of home page
---

<section
  id="cta-band"
  class="relative py-24 overflow-hidden"
  style="background-color: var(--color-primary);"
>
  <!-- Background image -->
  <img
    src="/images/hero/cta-bg.jpg"
    alt=""
    aria-hidden="true"
    class="absolute inset-0 w-full h-full object-cover object-bottom opacity-20"
    loading="lazy"
    decoding="async"
  />

  <!-- Large decorative letter -->
  <div
    class="absolute -right-8 top-1/2 -translate-y-1/2 font-display font-black uppercase leading-none pointer-events-none select-none hidden lg:block"
    style="font-size: 16rem; color: color-mix(in srgb, var(--color-primary-contrast) 6%, transparent);"
  >
    DS
  </div>

  <div class="relative max-w-4xl mx-auto px-6 text-center">
    <!-- Eyebrow -->
    <p
      class="font-sans text-xs uppercase tracking-[0.4em] font-semibold mb-6"
      style="color: color-mix(in srgb, var(--color-primary-contrast) 60%, transparent);"
    >
      Let's Create Together
    </p>

    <!-- Headline -->
    <h2
      class="font-display font-black uppercase leading-tight mb-6"
      style="color: var(--color-primary-contrast); font-size: clamp(2.2rem, 6vw, 4.5rem);"
    >
      Ready to Design<br />Your Dream Space?
    </h2>

    <!-- Supporting text -->
    <p
      class="font-sans text-lg max-w-xl mx-auto mb-10"
      style="color: color-mix(in srgb, var(--color-primary-contrast) 70%, transparent);"
    >
      Book a free consultation with Ar. Anchal Garg and let's transform your vision into a living, breathing space.
    </p>

    <!-- CTAs -->
    <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
      <a
        href="/contact"
        id="cta-band-contact"
        class="inline-flex items-center gap-2 font-bold uppercase tracking-widest rounded px-10 py-4 text-base transition-all duration-200 hover:scale-105"
        style="background-color: var(--color-primary-contrast); color: var(--color-primary);"
      >
        Contact Us
      </a>
      <a
        href="https://wa.me/919899473055"
        target="_blank"
        rel="noopener noreferrer"
        id="cta-band-whatsapp"
        class="inline-flex items-center gap-2 font-bold uppercase tracking-widest rounded px-8 py-4 text-base border-2 transition-all duration-200 hover:scale-105"
        style="border-color: color-mix(in srgb, var(--color-primary-contrast) 50%, transparent); color: var(--color-primary-contrast);"
      >
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        WhatsApp Us
      </a>
    </div>

    <!-- Phone -->
    <p class="mt-8 font-sans" style="color: color-mix(in srgb, var(--color-primary-contrast) 50%, transparent);">
      Or call us at
      <a href="tel:9899473055" class="font-semibold hover:opacity-80 transition-opacity" style="color: var(--color-primary-contrast);">
        9899473055
      </a>
    </p>
  </div>
</section>
