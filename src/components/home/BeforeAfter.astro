---
// BeforeAfter.astro — "We Deliver What We Promise" — 3D render vs completed space
---

<section id="before-after" class="py-24 bg-stone-900 dark:bg-background-dark overflow-hidden">
  <div class="max-w-7xl mx-auto px-6">

    <!-- Header -->
    <div class="text-center mb-12">
      <div class="flex items-center gap-4 justify-center mb-4">
        <div class="h-px w-12" style="background-color: var(--color-primary-contrast); opacity: 0.3;" />
        <span class="text-xs font-bold uppercase tracking-[0.3em] font-display" style="color: var(--color-primary-contrast); opacity: 0.6;">
          Proof of Promise
        </span>
        <div class="h-px w-12" style="background-color: var(--color-primary-contrast); opacity: 0.3;" />
      </div>
      <h2
        class="font-display font-black uppercase leading-tight"
        style="color: var(--color-primary-contrast); font-size: clamp(2rem, 5vw, 3.5rem);"
      >
        We Deliver<br />What We Promise
      </h2>
      <p class="font-sans mt-4 max-w-xl mx-auto" style="color: color-mix(in srgb, var(--color-primary-contrast) 60%, transparent);">
        Every project starts with a photorealistic 3D render — so you see your space before a single brick is laid. Then we build it exactly that way.
      </p>
    </div>

    <!-- Side-by-side comparison -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-10">

      <!-- Left: 3D Render -->
      <div class="relative rounded-lg overflow-hidden aspect-[4/3] group">
        <img
          src="/images/projects/pioneer-araya-1.jpg"
          alt="Pioneer Araya — Photorealistic 3D render before construction"
          class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
          loading="lazy"
          decoding="async"
        />
        <!-- Rust overlay tint -->
        <div class="absolute inset-0 opacity-20" style="background: var(--color-primary);" />
        <!-- Label -->
        <div class="absolute bottom-0 left-0 right-0 p-6" style="background: linear-gradient(to top, rgba(26,16,8,0.9) 0%, transparent 100%);">
          <span
            class="inline-block text-xs font-bold uppercase tracking-widest px-3 py-1 rounded-full mb-2 font-display"
            style="background-color: var(--color-primary); color: var(--color-primary-contrast);"
          >
            3D Render
          </span>
          <p class="font-sans text-sm" style="color: color-mix(in srgb, var(--color-primary-contrast) 70%, transparent);">
            What we promise — photo-realistic visualisation before construction begins
          </p>
        </div>
      </div>

      <!-- Right: Completed Space (real photo) -->
      <div class="relative rounded-lg overflow-hidden aspect-[4/3] group">
        <img
          src="/images/projects/vallab-vihar.jpg"
          alt="Vallab Vihar — Completed living space matching the design vision"
          class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
          loading="lazy"
          decoding="async"
        />
        <!-- Label -->
        <div class="absolute bottom-0 left-0 right-0 p-6" style="background: linear-gradient(to top, rgba(26,16,8,0.9) 0%, transparent 100%);">
          <span
            class="inline-block text-xs font-bold uppercase tracking-widest px-3 py-1 rounded-full mb-2 font-display"
            style="background-color: #4A3728; color: var(--color-primary-contrast);"
          >
            Completed Space
          </span>
          <p class="font-sans text-sm" style="color: color-mix(in srgb, var(--color-primary-contrast) 70%, transparent);">
            What we deliver — the same space built exactly as visualised
          </p>
        </div>
      </div>
    </div>

    <!-- Bottom emphasis -->
    <p
      class="text-center font-display font-black uppercase text-xl mt-10 tracking-wide"
      style="color: color-mix(in srgb, var(--color-primary-contrast) 40%, transparent);"
    >
      Render ↔ Reality
    </p>
  </div>
</section>
